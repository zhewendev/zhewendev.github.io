---
import type { CollectionEntry } from "astro:content";

interface Props {
  book: CollectionEntry<"books">;
}

const { book } = Astro.props;

const { title, author, cover, rating, status, tags } = book.data;
const rawCover = typeof cover === "string" ? cover : cover?.src;

const statusLabels = {
  reading: "在读",
  completed: "已读",
  "want-to-read": "想读",
};

const statusColors = {
  reading: "bg-blue-500",
  completed: "bg-green-500",
  "want-to-read": "bg-gray-400",
};
---

<article
  class="group relative flex gap-5 rounded-2xl bg-white p-5 shadow-sm transition-all duration-300 hover:shadow-lg hover:shadow-gray-200/50 dark:bg-gray-900 dark:hover:shadow-black/20"
>
  {/* Cover */}
  <div
    class="relative aspect-[2/3] w-24 flex-shrink-0 overflow-hidden rounded-xl shadow-md sm:w-28"
  >
    <img
      src={rawCover || "/images/placeholder/book.svg"}
      alt={title}
      class="h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-110"
      loading="lazy"
    />
    {/* Status Badge */}
    <div
      class:list={[
        "absolute top-2 left-2 rounded-full px-2.5 py-1 text-xs font-semibold text-white shadow-sm",
        statusColors[status],
      ]}
    >
      {statusLabels[status]}
    </div>
  </div>

  {/* Content */}
  <div class="flex flex-1 flex-col py-1">
    <h3
      class="line-clamp-2 text-base leading-snug font-bold text-gray-900 transition-colors group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400"
    >
      {title}
    </h3>
    <p class="mt-1.5 text-sm text-gray-500 dark:text-gray-400">{author}</p>

    {/* Rating */}
    {
      rating && (
        <div class="mt-3 flex items-center gap-2">
          <div class="flex text-amber-400">
            {Array.from({ length: 5 }).map((_, i) => (
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill={i < Math.floor(rating) ? "currentColor" : "none"}
                stroke="currentColor"
                stroke-width="2"
              >
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
              </svg>
            ))}
          </div>
          <span class="text-sm font-medium text-gray-600 dark:text-gray-400">
            {rating}
          </span>
        </div>
      )
    }

    {/* Tags */}
    {
      tags && tags.length > 0 && (
        <div class="mt-auto flex flex-wrap gap-1.5 pt-4">
          {tags.slice(0, 2).map(tag => (
            <span class="inline-flex items-center rounded-md bg-gray-100 px-2 py-1 text-xs font-medium text-gray-600 dark:bg-gray-800 dark:text-gray-400">
              {tag}
            </span>
          ))}
        </div>
      )
    }
  </div>

  {/* Click to open modal */}
  <button
    type="button"
    class="absolute inset-0 rounded-2xl focus:ring-2 focus:ring-blue-500/50 focus:outline-none"
    onclick={`window.openModal('book-modal-${book.id}')`}
    aria-label={`查看《${title}》详情`}></button>
</article>
