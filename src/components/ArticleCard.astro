---
import { getRelativeLocaleUrl } from "astro:i18n";
import type { CollectionEntry } from "astro:content";
import FormattedDate from "./FormattedDate.astro";

interface Props {
  post: CollectionEntry<"posts">;
  variant?: "default" | "compact" | "featured";
}

const { post, variant = "default" } = Astro.props;
const locale = Astro.currentLocale ?? "en";

// Get post metadata
const {
  title,
  description,
  pubDatetime,
  modDatetime,
  heroImage,
  tags,
  readingTime,
} = post.data;

// Placeholder image path
const placeholderImage = "/images/placeholder/article.svg";
const imageUrl =
  typeof heroImage === "string"
    ? heroImage
    : (heroImage?.src ?? placeholderImage);

// Format reading time
const readTime = readingTime ?? "5 min read";
---

{
  variant === "featured" && (
    <article class="group relative overflow-hidden rounded-2xl bg-white shadow-sm transition-all duration-500 hover:shadow-xl hover:shadow-gray-200/50 dark:bg-gray-900 dark:hover:shadow-black/20">
      <a
        href={getRelativeLocaleUrl(locale, `posts/${post.id}`)}
        class="flex flex-col md:flex-row"
      >
        {/* Image */}
        <div class="relative aspect-[16/10] w-full overflow-hidden md:aspect-auto md:w-2/5">
          <img
            src={imageUrl}
            alt={title}
            class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-110"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100" />
        </div>

        {/* Content */}
        <div class="flex flex-1 flex-col justify-between p-6 md:p-8">
          <div>
            {/* Tags */}
            {tags && tags.length > 0 && (
              <div class="mb-3 flex flex-wrap gap-2">
                {tags.slice(0, 2).map(tag => (
                  <span class="inline-flex items-center rounded-full bg-blue-50 px-3 py-1 text-xs font-medium text-blue-700 dark:bg-blue-900/30 dark:text-blue-300">
                    {tag}
                  </span>
                ))}
              </div>
            )}

            {/* Title */}
            <h3 class="mb-3 text-xl leading-tight font-bold text-gray-900 transition-colors group-hover:text-blue-600 md:text-2xl dark:text-white dark:group-hover:text-blue-400">
              {title}
            </h3>

            {/* Description */}
            {description && (
              <p class="line-clamp-2 text-sm leading-relaxed text-gray-600 dark:text-gray-400">
                {description}
              </p>
            )}
          </div>

          {/* Meta */}
          <div class="mt-6 flex items-center gap-4 text-sm text-gray-500 dark:text-gray-500">
            <div class="flex items-center gap-1.5">
              <svg
                class="h-4 w-4"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                />
              </svg>
              <FormattedDate date={modDatetime ?? pubDatetime} />
            </div>
            <span class="text-gray-300 dark:text-gray-700">·</span>
            <div class="flex items-center gap-1.5">
              <svg
                class="h-4 w-4"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                />
              </svg>
              <span>{readTime}</span>
            </div>
          </div>
        </div>
      </a>
    </article>
  )
}

{
  variant === "default" && (
    <article class="group relative">
      <a
        href={getRelativeLocaleUrl(locale, `posts/${post.id}`)}
        class="flex gap-5 rounded-xl p-3 transition-all duration-300 hover:bg-gray-50 dark:hover:bg-gray-800/50"
      >
        {/* Image - Left side */}
        <div class="relative aspect-[4/3] w-32 flex-shrink-0 overflow-hidden rounded-lg shadow-sm md:w-40">
          <img
            src={imageUrl}
            alt={title}
            class="h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-110"
            loading="lazy"
          />
        </div>

        {/* Content - Right side */}
        <div class="flex flex-1 flex-col justify-between py-1">
          <div>
            {/* Title */}
            <h3 class="mb-2 line-clamp-2 text-base leading-snug font-semibold text-gray-900 transition-colors group-hover:text-blue-600 dark:text-gray-100 dark:group-hover:text-blue-400">
              {title}
            </h3>

            {/* Description */}
            {description && (
              <p class="line-clamp-2 text-sm leading-relaxed text-gray-600 dark:text-gray-400">
                {description}
              </p>
            )}
          </div>

          {/* Meta */}
          <div class="mt-3 flex items-center gap-3 text-xs text-gray-500 dark:text-gray-500">
            <span class="inline-flex items-center gap-1">
              <svg
                class="h-3.5 w-3.5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                />
              </svg>
              <FormattedDate date={modDatetime ?? pubDatetime} />
            </span>
            {tags && tags.length > 0 && (
              <>
                <span class="text-gray-300 dark:text-gray-700">·</span>
                <span class="inline-flex items-center gap-1">
                  <svg
                    class="h-3.5 w-3.5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"
                    />
                  </svg>
                  <span class="max-w-[100px] truncate">{tags[0]}</span>
                </span>
              </>
            )}
          </div>
        </div>
      </a>
    </article>
  )
}

{
  variant === "compact" && (
    <article class="group">
      <a
        href={getRelativeLocaleUrl(locale, `posts/${post.id}`)}
        class="flex items-start gap-3 py-2"
      >
        {/* Small thumbnail */}
        <div class="relative aspect-square w-16 flex-shrink-0 overflow-hidden rounded-md">
          <img
            src={imageUrl}
            alt={title}
            class="h-full w-full object-cover"
            loading="lazy"
          />
        </div>

        {/* Content */}
        <div class="min-w-0 flex-1">
          <h4 class="group-hover:text-accent line-clamp-2 text-sm leading-snug font-medium transition-colors">
            {title}
          </h4>
          <div class="text-muted-foreground mt-1 text-xs">
            <FormattedDate date={modDatetime ?? pubDatetime} />
          </div>
        </div>
      </a>
    </article>
  )
}
