---
interface Props {
  title: string;
  url: string;
}

const { title, url } = Astro.props;

// Share URLs
const shareUrls = {
  twitter: `https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(url)}`,
  facebook: `https://www.facebook.com/sharer.php?u=${encodeURIComponent(url)}`,
  linkedin: `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`,
  copy: url,
};
---

<div class="flex flex-wrap items-center gap-4">
  {/* Like Button */}
  <button
    id="like-btn"
    class="hover:bg-accent hover:text-accent-foreground flex items-center gap-2 rounded-full border px-4 py-2 text-sm transition-colors"
    aria-label="点赞"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path
        d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"
      ></path>
    </svg>
    <span id="like-count">0</span>
  </button>

  {/* Share Buttons */}
  <div class="flex items-center gap-2">
    <span class="text-muted-foreground text-sm">分享:</span>

    {/* Twitter */}
    <a
      href={shareUrls.twitter}
      target="_blank"
      rel="noopener noreferrer"
      class="hover:bg-accent hover:text-accent-foreground flex h-9 w-9 items-center justify-center rounded-full border transition-colors"
      aria-label="分享到 Twitter"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="currentColor"
      >
        <path
          d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
        ></path>
      </svg>
    </a>

    {/* Facebook */}
    <a
      href={shareUrls.facebook}
      target="_blank"
      rel="noopener noreferrer"
      class="hover:bg-accent hover:text-accent-foreground flex h-9 w-9 items-center justify-center rounded-full border transition-colors"
      aria-label="分享到 Facebook"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="currentColor"
      >
        <path
          d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
        ></path>
      </svg>
    </a>

    {/* Copy Link */}
    <button
      id="copy-link-btn"
      data-url={shareUrls.copy}
      class="hover:bg-accent hover:text-accent-foreground flex h-9 w-9 items-center justify-center rounded-full border transition-colors"
      aria-label="复制链接"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"
        ></path>
        <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"
        ></path>
      </svg>
    </button>
  </div>
</div>

<script>
  // Like functionality (client-side only for demo)
  const likeBtn = document.getElementById("like-btn");
  const likeCount = document.getElementById("like-count");

  if (likeBtn && likeCount) {
    // Get stored likes
    const articleId = window.location.pathname;
    const storedLikes = localStorage.getItem(`likes-${articleId}`);
    let likes = storedLikes ? parseInt(storedLikes, 10) : 0;
    let hasLiked = localStorage.getItem(`hasLiked-${articleId}`) === "true";

    // Update display
    likeCount.textContent = likes.toString();
    if (hasLiked) {
      likeBtn.classList.add("bg-accent", "text-accent-foreground");
    }

    likeBtn.addEventListener("click", () => {
      if (!hasLiked) {
        likes++;
        hasLiked = true;
        localStorage.setItem(`likes-${articleId}`, likes.toString());
        localStorage.setItem(`hasLiked-${articleId}`, "true");
        likeCount.textContent = likes.toString();
        likeBtn.classList.add("bg-accent", "text-accent-foreground");
      }
    });
  }

  // Copy link functionality
  const copyBtn = document.getElementById("copy-link-btn");
  if (copyBtn) {
    copyBtn.addEventListener("click", async () => {
      const url = copyBtn.getAttribute("data-url");
      if (url) {
        await navigator.clipboard.writeText(url);

        // Show feedback
        const originalHTML = copyBtn.innerHTML;
        copyBtn.innerHTML = `
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
        `;
        setTimeout(() => {
          copyBtn.innerHTML = originalHTML;
        }, 2000);
      }
    });
  }
</script>
