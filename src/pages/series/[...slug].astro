---
import { getCollection, render } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import ArticleCard from "@/components/ArticleCard.astro";
import config from "@/config";

export async function getStaticPaths() {
  const series = await getCollection("series");
  return series.map(s => ({
    params: { slug: s.id },
    props: { series: s },
  }));
}

const { series } = Astro.props;
const locale = Astro.currentLocale ?? config.site.lang;

const { Content } = await render(series);

// Get related posts (posts with matching tags)
const allPosts = await getCollection("posts");
const seriesTags = series.data.tags || [];
const relatedPosts = allPosts
  .filter(
    post =>
      !post.data.draft && post.data.tags?.some(tag => seriesTags.includes(tag))
  )
  .slice(0, 6);

const breadcrumbItems = [
  { name: "专题", href: getRelativeLocaleUrl(locale, "series") },
  { name: series.data.title },
];
---

<Layout title={`${series.data.title} | 专题 | ${config.site.title}`}>
  <Header />
  <main id="main-content" class="app-layout py-8">
    <Breadcrumb items={breadcrumbItems} />

    {/* Series Header */}
    <header class="mb-10">
      <div class="mb-4 flex flex-wrap gap-2">
        {
          series.data.tags?.map(tag => (
            <span class="bg-secondary text-secondary-foreground rounded-full px-3 py-1 text-sm">
              {tag}
            </span>
          ))
        }
      </div>
      <h1 class="text-3xl font-bold md:text-4xl">{series.data.title}</h1>
      <p class="text-muted-foreground mt-4 text-lg">
        {series.data.description}
      </p>
    </header>

    {/* Series Content */}
    <div class="prose prose-lg mb-12 max-w-none">
      <Content />
    </div>

    {/* Related Posts */}
    {
      relatedPosts.length > 0 && (
        <section>
          <h2 class="mb-6 text-2xl font-semibold">相关文章</h2>
          <div class="divide-border divide-y">
            {relatedPosts.map(post => (
              <ArticleCard post={post} variant="default" />
            ))}
          </div>
        </section>
      )
    }
  </main>
  <Footer />
</Layout>
