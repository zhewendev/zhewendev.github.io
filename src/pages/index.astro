---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Hero from "@/components/Hero.astro";
import ArticleCard from "@/components/ArticleCard.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import config from "@/config";

const POSTS_PER_PAGE = 10; // 首页显示10篇文章

const locale = Astro.currentLocale ?? config.site.lang;

// Get all posts
const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);

// Get series for sidebar
const allSeries = await getCollection("series");
const featuredSeries = allSeries.filter(s => s.data.featured).slice(0, 3);

// Get books for sidebar (recent collections)
const allBooks = await getCollection("books");
const recentBooks = allBooks.slice(0, 3);

// Get thoughts for sidebar
const allThoughts = await getCollection("thoughts");
const recentThoughts = allThoughts
  .sort(
    (a, b) =>
      new Date(b.data.pubDatetime).getTime() -
      new Date(a.data.pubDatetime).getTime()
  )
  .slice(0, 3);

// Pagination logic for homepage
const currentPage = 1;
const totalPosts = sortedPosts.length;
const totalPages = Math.ceil(totalPosts / POSTS_PER_PAGE);
const paginatedPosts = sortedPosts.slice(0, POSTS_PER_PAGE);

// Generate page numbers for pagination
function getPageNumbers(current: number, last: number): (number | string)[] {
  if (last <= 7) {
    return Array.from({ length: last }, (_, i) => i + 1);
  }

  const pages: (number | string)[] = [];
  pages.push(1);

  if (current <= 3) {
    pages.push(2, 3, 4);
    pages.push("...");
    pages.push(last);
  } else if (current >= last - 2) {
    pages.push("...");
    pages.push(last - 3, last - 2, last - 1, last);
  } else {
    pages.push("...");
    pages.push(current - 1, current, current + 1);
    pages.push("...");
    pages.push(last);
  }

  return pages;
}

const pageNumbers = getPageNumbers(currentPage, totalPages);
---

<Layout>
  <Header />
  <main id="main-content">
    {/* Hero Section */}
    <Hero />

    <div
      class="mx-auto w-full max-w-[1400px] px-4 py-12 sm:px-6 lg:px-8 xl:px-12"
    >
      <div class="grid gap-10 lg:grid-cols-[1fr_340px]">
        {/* Main Content - Left Column */}
        <div>
          {/* Section Header */}
          <div class="mb-6 flex items-center justify-between">
            <h2 class="text-xl font-bold text-gray-900 dark:text-white">
              最新文章
            </h2>
          </div>

          {/* Article List */}
          <div class="space-y-1">
            {
              paginatedPosts.map(post => (
                <ArticleCard post={post} variant="default" />
              ))
            }
          </div>

          {/* Pagination */}
          {
            totalPages > 1 && (
              <nav
                class="mt-10 flex items-center justify-center gap-1"
                role="navigation"
                aria-label="Pagination"
              >
                {/* Page Numbers */}
                <div class="flex items-center gap-1">
                  {pageNumbers.map(num =>
                    num === "..." ? (
                      <span class="px-2 text-gray-400 dark:text-gray-600">
                        ...
                      </span>
                    ) : (
                      <a
                        href={num === 1 ? "/" : `/posts/${num}/`}
                        class:list={[
                          "min-w-[40px] rounded-lg px-3 py-2 text-center text-sm font-medium transition-all",
                          num === currentPage
                            ? "bg-gray-900 text-white dark:bg-white dark:text-gray-900"
                            : "text-gray-600 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-800",
                        ]}
                        aria-current={num === currentPage ? "page" : undefined}
                      >
                        {num}
                      </a>
                    )
                  )}
                </div>

                {/* Next Button */}
                {currentPage < totalPages && (
                  <a
                    href="/posts/2/"
                    class="ml-2 inline-flex items-center gap-1 rounded-lg px-4 py-2 text-sm font-medium text-gray-600 transition-all hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-800"
                  >
                    下一页
                    <svg
                      class="h-4 w-4"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M9 5l7 7-7 7"
                      />
                    </svg>
                  </a>
                )}
              </nav>
            )
          }
        </div>

        {/* Sidebar - Right Column */}
        <aside class="space-y-8">
          {/* 专题推荐 */}
          {
            featuredSeries.length > 0 && (
              <div class="rounded-xl bg-white p-5 shadow-sm dark:bg-gray-900">
                <h3 class="mb-4 text-base font-bold text-gray-900 dark:text-white">
                  专题推荐
                </h3>
                <div class="space-y-3">
                  {featuredSeries.map(series => (
                    <a
                      href={getRelativeLocaleUrl(locale, `series/${series.id}`)}
                      class="group flex items-center gap-3"
                    >
                      <div class="relative h-14 w-20 flex-shrink-0 overflow-hidden rounded-lg bg-gray-100 dark:bg-gray-800">
                        <img
                          src="/images/placeholder/article.svg"
                          alt={series.data.title}
                          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                        />
                      </div>
                      <div class="min-w-0 flex-1">
                        <h4 class="truncate text-sm font-medium text-gray-900 transition-colors group-hover:text-blue-600 dark:text-gray-100 dark:group-hover:text-blue-400">
                          {series.data.title}
                        </h4>
                        <p class="mt-0.5 line-clamp-1 text-xs text-gray-500 dark:text-gray-500">
                          {series.data.description}
                        </p>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            )
          }

          {/* 最近收藏 */}
          {
            recentBooks.length > 0 && (
              <div class="rounded-xl bg-white p-5 shadow-sm dark:bg-gray-900">
                <h3 class="mb-4 text-base font-bold text-gray-900 dark:text-white">
                  最近收藏
                </h3>
                <ul class="space-y-2.5">
                  {recentBooks.map(book => (
                    <li>
                      <a
                        href={getRelativeLocaleUrl(locale, "books")}
                        class="group flex items-center gap-2 text-sm"
                      >
                        <span class="h-1.5 w-1.5 flex-shrink-0 rounded-full bg-blue-500" />
                        <span class="truncate text-gray-700 transition-colors group-hover:text-blue-600 dark:text-gray-300 dark:group-hover:text-blue-400">
                          {book.data.title}
                        </span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )
          }

          {/* 最近随想 */}
          {
            recentThoughts.length > 0 && (
              <div class="rounded-xl bg-white p-5 shadow-sm dark:bg-gray-900">
                <h3 class="mb-4 text-base font-bold text-gray-900 dark:text-white">
                  最近随想
                </h3>
                <ul class="space-y-3">
                  {recentThoughts.map(thought => (
                    <li>
                      <a
                        href={getRelativeLocaleUrl(locale, "thoughts")}
                        class="group block"
                      >
                        <p class="line-clamp-2 text-sm text-gray-700 transition-colors group-hover:text-blue-600 dark:text-gray-300 dark:group-hover:text-blue-400">
                          {thought.body?.slice(0, 60)}...
                        </p>
                        <span class="mt-1 block text-xs text-gray-400 dark:text-gray-500">
                          {new Date(
                            thought.data.pubDatetime
                          ).toLocaleDateString("zh-CN", {
                            month: "short",
                            day: "numeric",
                          })}
                        </span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )
          }
        </aside>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
